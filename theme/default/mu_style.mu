html as mu_style do
.mu-keyword {
    color: #ff7b72;
    font-weight: bold;
}

/* meta, html, as, do, end */
.mu-at {
    color: #79c0ff;
}

/* , Hub, en */
.mu-string {
    color: #a5d6ff;
}

/* hodnoty za dvojtečkou */
.mu-tag {
    color: #7ee787;
}

/* standardní HTML tagy */
.mu-comment {
    color: #8b949e;
    font-style: italic;
}
end